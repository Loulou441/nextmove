# Copier ce fichier en ".env" et renseigner les valeurs (le ".env" réel n'est jamais versionné).

# --- Secrets ---
GROQ_API_KEY=

# --- Modèles Groq (un modèle par sport, optionnel) ---
MODEL_NAME_PICKELBALL=llama-3.3-70b-versatile
MODEL_NAME_FOOTBALL=llama-3.3-70b-versatile
MODEL_NAME_PADEL=llama-3.3-70b-versatile

# Température des complétions (0.0 = réponses déterministes)
GROQ_TEMPERATURE=0.0

# --- Personnalisation de l'app / white-label ---
APP_PAGE_TITLE=NextMove
APP_PAGE_ICON=🏓
DEFAULT_SPORT=pickleball

# --- Données ---
# Dossier contenant demo_games.csv / demo_events.csv (par défaut: <racine du projet>/data)
DATA_DIR=

# --- Configuration native Streamlit (optionnelle, préfixe STREAMLIT_) ---
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_MAX_UPLOAD_SIZE=500
