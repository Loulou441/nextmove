# TactiCore Web-App - Configuration .env

# ============================================
# BACKEND CONFIGURATION
# ============================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Database
DB_PATH=./data/tacticore.db
DB_TYPE=sqlite  # sqlite, postgresql

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend Server
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# API URL (from frontend perspective)
REACT_APP_API_URL=http://localhost:8000

# ============================================
# AI/ML SERVICES
# ============================================

# Groq API (pour recommandations IA)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# SECURITY
# ============================================

# JWT (à implémenter)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=*

# ============================================
# LOGGING & DEBUG
# ============================================

LOG_LEVEL=INFO
DEBUG=False

# ============================================
# FEATURES FLAGS
# ============================================

ENABLE_WEBSOCKET=True
ENABLE_POLLING_FALLBACK=True
POLLING_INTERVAL_MS=5000
